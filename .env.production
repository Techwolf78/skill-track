# RxOne Production Environment Configurations
VITE_API_BASE_URL=https://rxone.onrender.com

# CDN-based ML Model URLs
# COCO-SSD object detection model weights
VITE_COCOSSD_MODEL_URL=https://storage.googleapis.com/tfjs-models/savedmodel/coco-ssd/lite_mobilenet_v2/model.json

# Xenova Distilbert NLP model remote host & template path
VITE_XENOVA_MODEL_CDN_URL=https://huggingface.co/
VITE_XENOVA_MODEL_CDN_PATH={model}/resolve/{revision}/
